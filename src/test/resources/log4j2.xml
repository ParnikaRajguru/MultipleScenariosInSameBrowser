<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- ================== PROPERTIES ================== -->
    <Properties>
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %c{1} - %msg%n
        </Property>

        <Property name="LOG_DIR">target/logs</Property>
        <Property name="LOG_FILE">${LOG_DIR}/framework.log</Property>
    </Properties>

    <!-- ================== APPENDERS ================== -->
    <Appenders>

        <!-- ✅ Console Logs -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}" />
        </Console>

        <!-- ✅ Rolling File Logs -->
        <RollingFile
                name="FileLogger"
                fileName="${LOG_FILE}"
                filePattern="${LOG_DIR}/framework-%d{yyyy-MM-dd}.log">

            <PatternLayout pattern="${LOG_PATTERN}" />

            <Policies>
                <!-- Roll file every day -->
                <TimeBasedTriggeringPolicy interval="1" />
            </Policies>

            <DefaultRolloverStrategy max="14" />
        </RollingFile>

    </Appenders>

    <!-- ================== LOGGERS ================== -->
    <Loggers>

        <!-- ✅ Reduce Selenium noise -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="FileLogger" />
        </Logger>

        <!-- ✅ Cucumber logs -->
        <Logger name="io.cucumber" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="FileLogger" />
        </Logger>

        <!-- ✅ Your framework logs -->
        <Logger name="com.deno" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="FileLogger" />
        </Logger>

        <!-- ✅ ROOT logger -->
        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="FileLogger" />
        </Root>

    </Loggers>

</Configuration>